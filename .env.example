APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Subdirectory example: APP_URL=https://cbp.africacdc.org/warcc
# When APP_URL has a path, do NOT run `php artisan route:cache` (breaks GET / with 405).

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Report Assistant (OpenAI-compatible API)
AI_ENABLED=true
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT=120
AI_MAX_REPORTS_PER_MERGE=10

# Development test logins (/test-accounts, /test-login) — default true when APP_ENV=local
# Set to false in production (required for go-live)
ENABLE_DEV_LOGIN=

# Production checklist: APP_ENV=production, APP_DEBUG=false, ENABLE_DEV_LOGIN=false
# Run: php artisan migrate --force && php artisan db:seed --force
# Cron: * * * * * cd /path/to/warcc && php artisan schedule:run >> /dev/null 2>&1

# Attendance — staff clocked in after this time are marked "late" (24h, e.g. 09:00)
ATTENDANCE_LATE_AFTER=09:00

# Microsoft SSO (Azure AD app registration) & Graph (email reminders)
# Register app: Azure Portal → App registrations → New → Web redirect URI below
# Required permissions: openid, profile, email, User.Read (delegated)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"
MICROSOFT_MAIL_FROM=

# Email reminders (Microsoft Graph)
REMINDERS_ENABLED=true
REMINDER_ACTIVITY_REPORTS_ENABLED=true
REMINDER_ACTIVITY_REPORT_COOLDOWN_DAYS=3
REMINDER_DAILY_AT=08:00
